<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:left="@dimen/padding_1" android:top="@dimen/padding_1"
                android:right="@dimen/padding_1" android:bottom="@dimen/padding_1">
                <shape android:shape="rectangle">
                    <solid android:color="@color/white" />
                    <corners android:radius="@dimen/btn_radius_10" />
                    <stroke
                        android:width="1dp"
                        android:color="@color/primary_blue" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <corners android:radius="@dimen/btn_radius_10" />
            <stroke
                android:width="1.5dp"
                android:color="@color/primary_blue" />
        </shape>
    </item>

</selector>