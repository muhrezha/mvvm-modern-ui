<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Multiple shadow layers untuk efek blur -->
    <item android:left=".6dp" android:top="0dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#0ECCCCCC"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item android:left=".6dp" android:top="0dp" android:right="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <solid android:color="#09CCCCCC"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <item android:left=".6dp" android:top="0dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <solid android:color="#09008BFF"/>
            <corners android:radius="18dp"/>
        </shape>
    </item>

    <!-- Content layer -->
    <item
        android:left="1dp"
        android:top="1dp"
        android:right="4dp"
        android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@android:color/white"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="0.5dp"
                android:color="#0ACCCCCC"/> <!-- Biru sangat muda -->
        </shape>
    </item>

</layer-list>