<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Shadow layer -->
    <item>
        <shape android:left="2dp" android:shape="rectangle">
            <solid android:color="#07000000" /> <!-- shadow ringan -->
            <corners
                android:bottomLeftRadius="23dp"
                android:bottomRightRadius="23dp" />
        </shape>
    </item>

    <!-- Foreground (main content) -->
    <item android:left="2dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <solid android:color="@color/white" />
            <stroke
                android:width="0dp"
                android:color="#91DDDDDD" />
            <corners
                android:bottomLeftRadius="23dp"
                android:bottomRightRadius="23dp" />
        </shape>
    </item>

</layer-list>
