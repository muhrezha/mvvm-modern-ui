                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingTop="14dp"
                    android:paddingHorizontal="12dp"
                    android:gravity="center"
                    app:contentScrim="@android:color/transparent">

                    <!-- Item 1 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@android:color/transparent">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/card_template_white"
                            android:clickable="true"
                            android:padding="10dp">

                            <RelativeLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content">

                                <ImageView
                                    android:src="@drawable/ic_transaction_outline"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"
                                    android:layout_centerInParent="true"/>

                            </RelativeLayout>

                        </RelativeLayout>

                        <TextView
                            android:text="@string/transaction"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:maxLines="2"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <!-- Item 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/card_template_white"
                            android:padding="10dp">

                            <ImageView
                                android:src="@drawable/ic_voucher_outline"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_centerInParent="true"/>

                        </RelativeLayout>

                        <TextView
                            android:text="@string/voucher"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:maxLines="2"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <!-- Item 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/card_template_white"
                            android:padding="10dp">

                            <ImageView
                                android:src="@drawable/ic_friends_outline"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_centerInParent="true"/>

                        </RelativeLayout>

                        <TextView
                            android:text="@string/teman"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:maxLines="2"
                            android:textSize="13sp"/>

                    </LinearLayout>

                    <!-- Item 4 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center">

                        <RelativeLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/card_template_white"
                            android:padding="10dp">

                            <ImageView
                                android:src="@drawable/ic_cart_outline"
                                android:layout_width="30dp"
                                android:layout_height="28dp"
                                android:layout_centerInParent="true"/>

                        </RelativeLayout>

                        <TextView
                            android:text="@string/cart"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:maxLines="2"
                            android:textSize="13sp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </com.google.android.material.appbar.CollapsingToolbarLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:id="@+id/yellowCard"
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:orientation="horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!--Detail layout profile-->
        <include
            android:id="@+id/layoutProfileFloating"
            layout="@layout/view_profile_floating_bar"
            android:visibility="visible"/>

        <!--Detail layout switcher-->
        <RelativeLayout
            android:id="@+id/layout_switcher"
            android:visibility="visible"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:background="@drawable/card_home_collapse_bar">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Stack Overflow Style Switch -->
                    <FrameLayout
                        android:id="@+id/switchContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="30dp"
                        android:background="@drawable/switch_background"
                        android:padding="4dp">

                        <!-- Selection Indicator -->
                        <View
                            android:id="@+id/selectionIndicator"
                            android:layout_width="100dp"
                            android:layout_height="match_parent"
                            android:background="@drawable/switch_indicator" />

                        <!-- Options Container -->
                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="20dp"
                            android:orientation="horizontal">

                            <!-- Mobile Option -->
                            <TextView
                                android:id="@+id/tv_pribadi"
                                android:layout_width="100dp"
                                android:layout_height="match_parent"
                                android:text="Pribadi"
                                android:gravity="center"
                                android:textColor="@color/white"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                            <!-- Email Option -->
                            <TextView
                                android:id="@+id/tv_employee"
                                android:layout_width="100dp"
                                android:layout_height="match_parent"
                                android:text="Karyawan"
                                android:gravity="center"
                                android:textColor="@color/yellow"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:clickable="true"
                                android:focusable="true" />

                        </LinearLayout>


                    </FrameLayout>

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="80dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" >

        <include
            android:id="@+id/layoutNested"
            layout="@layout/view_nested_home">
        </include>

    </androidx.core.widget.NestedScrollView>


</androidx.coordinatorlayout.widget.CoordinatorLayout>
