<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="wrap_content"
    android:layout_width="wrap_content">

    <!--Detail layout profile-->
    <LinearLayout
        android:visibility="visible"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        android:background="@drawable/card_home_collapse_bar"
        android:paddingLeft="18dp"
        android:paddingRight="18dp">

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1">

            <!-- Circular Image View -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPhoto"
                android:layout_width="50dp"
                android:layout_height="50dp"
                app:cardCornerRadius="75dp"
                android:layout_marginLeft="8dp"
                android:layout_centerVertical="true">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <!-- Progress Bar -->
                    <ProgressBar
                        android:id="@+id/progressBar"
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_centerInParent="true"
                        android:indeterminate="true"
                        android:visibility="visible" />

                    <!-- Circular Image -->
                    <ImageView
                        android:id="@+id/circularImgV"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:scaleType="centerCrop"
                        android:background="@drawable/circle_image"
                        android:visibility="invisible" />

                    <!-- Error Icon (hidden by default) -->
                    <ImageView
                        android:id="@+id/errorIcon"
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:layout_centerInParent="true"
                        android:src="@drawable/ic_image_error"
                        android:visibility="gone"
                        app:tint="#666666" />

                </RelativeLayout>

            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_toRightOf="@+id/cardPhoto"
                android:layout_centerVertical="true"
                android:layout_marginLeft="10dp">

                <TextView
                    android:id="@+id/tvGreeting"
                    android:textSize="12sp"
                    android:text="Good Morning"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textAppearance="@style/MyTextViewStyle"/>

                <TextView
                    android:id="@+id/tvFullname"
                    android:textSize="14sp"
                    android:text="Abbas"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/white"
                    android:textAppearance="@style/MyTextViewStyle"/>


            </LinearLayout>

        </RelativeLayout>

        <RelativeLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:paddingEnd="8dp">

            <LinearLayout
                android:id="@+id/linearLeft"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/shape_border_radius_circle"
                android:visibility="invisible">

                <RelativeLayout
                    android:layout_width="37dp"
                    android:layout_height="37dp"
                    android:background="@drawable/ripple_circle"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:padding="5dp"
                        android:src="@drawable/ic_switch_user"
                        android:layout_centerInParent="true"/>

                </RelativeLayout>

            </LinearLayout>

            <LinearLayout
                android:id="@+id/linearRight"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:background="@drawable/shape_border_radius_circle"
                android:visibility="visible">

                <RelativeLayout
                    android:id="@+id/rlNotificationFloating"
                    android:layout_width="37dp"
                    android:layout_height="37dp"
                    android:background="@drawable/ripple_circle"
                    android:clickable="true">

                    <ImageView
                        android:layout_width="37dp"
                        android:layout_height="37dp"
                        android:padding="8dp"
                        android:src="@drawable/ic_notif_outline_yellow"
                        android:layout_centerInParent="true"/>

                </RelativeLayout>

            </LinearLayout>

        </RelativeLayout>

    </LinearLayout>

</RelativeLayout>