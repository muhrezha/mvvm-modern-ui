<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="false"
    tools:context=".views.payungin.views.dashboard.fragments.LearningFragment">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.google.android.material.appbar.AppBarLayout
                android:id="@+id/ablLearning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:theme="@style/ThemeOverlay.AppCompat.Dark.ActionBar">

                <com.google.android.material.appbar.CollapsingToolbarLayout
                    android:id="@+id/ctlLearning"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    app:contentScrim="@color/yellow"
                    app:layout_scrollFlags="scroll|snap|exitUntilCollapsed"
                    android:fitsSystemWindows="false">

                    <!-- Ganti ImageView dengan ViewPager2 untuk image slider -->
                    <androidx.viewpager2.widget.ViewPager2
                        android:id="@+id/vp2HeaderLearning"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="@color/grey_100"
                        app:layout_collapseMode="parallax" />

                    <!-- Indicator untuk slider -->
                    <!-- Ganti TabLayout dengan LinearLayout -->
                    <LinearLayout
                        android:id="@+id/llDotsSlideLearning"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="8dp"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:padding="8dp" />

                    <androidx.appcompat.widget.Toolbar
                        android:id="@+id/tLearning"
                        android:layout_width="match_parent"
                        android:layout_height="?attr/actionBarSize"
                        app:layout_collapseMode="pin"
                        app:popupTheme="@style/ThemeOverlay.AppCompat.Dark">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:id="@+id/imgBackLearning"
                                android:layout_width="30dp"
                                android:layout_height="30dp"
                                android:layout_centerVertical="true"
                                android:layout_alignParentStart="true"
                                android:src="@drawable/ic_left_filled_yellow"
                                android:scaleType="fitCenter"
                                android:background="@drawable/ripple_circle"
                                android:clickable="true"/>

                            <!-- Title yang akan muncul hanya saat collapsed -->
                            <TextView
                                android:id="@+id/tTitleLearning"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerInParent="true"
                                android:text="@string/events"
                                android:textColor="@color/white"
                                android:textSize="18sp"
                                android:textStyle="bold"
                                android:visibility="visible"/>

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginRight="8dp"
                                android:clickable="true"
                                android:background="@drawable/ripple_circle"
                                android:layout_centerVertical="true"
                                android:layout_alignParentEnd="true">

                                <ImageView
                                    android:padding="6dp"
                                    android:src="@drawable/ic_wishlist_filled_yellow"
                                    android:layout_width="30dp"
                                    android:layout_height="30dp"/>

                            </LinearLayout>

                        </RelativeLayout>

                    </androidx.appcompat.widget.Toolbar>

                </com.google.android.material.appbar.CollapsingToolbarLayout>

            </com.google.android.material.appbar.AppBarLayout>

            <LinearLayout
                android:id="@+id/llBarFloatingLearning"
                android:layout_width="match_parent"
                android:layout_height="70dp"
                android:background="@drawable/card_template_bottoms"
                android:elevation="0dp"
                app:cardCornerRadius="0dp"
                app:cardBackgroundColor="@color/white"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <LinearLayout
                    android:id="@+id/greenCardContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:gravity="center"
                    android:background="@android:color/transparent">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="7dp"
                        android:layout_marginBottom="3dp">

                        <!-- LinearLayout utama dengan white background, radius 13dp dan shadow -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:background="@drawable/search_container_with_shadow"
                            android:paddingLeft="12dp"
                            android:paddingRight="12dp"
                            android:gravity="center">

                            <!-- Icon pencarian di kiri -->
                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:layout_gravity="center_vertical"
                                android:src="@drawable/ic_search_gray"
                                android:layout_marginEnd="10dp" />

                            <!-- Input text tanpa border -->
                            <EditText
                                android:id="@+id/inputSearch"
                                android:layout_width="0dp"
                                android:layout_height="27dp"
                                android:layout_weight="1"
                                android:background="@null"
                                android:hint="Find learning..."
                                android:padding="0dp"
                                android:textSize="16sp"
                                android:gravity="center_vertical"
                                android:maxLines="1"
                                android:lines="1"
                                android:inputType="text"
                                android:imeOptions="actionDone"
                                android:singleLine="true"
                                android:textColor="@color/black"/>

                            <!-- LinearLayout dengan radius 10dp untuk icon setting -->
                            <LinearLayout
                                android:id="@+id/llFilterLearning"
                                android:layout_width="27dp"
                                android:layout_height="27dp"
                                android:background="@drawable/setting_background"
                                android:gravity="center"
                                android:layout_gravity="center_vertical"
                                android:layout_marginStart="8dp">

                                <!-- Icon setting -->
                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/ic_filter_white" />

                            </LinearLayout>

                        </LinearLayout>

                    </LinearLayout>


                </LinearLayout>

            </LinearLayout>

            <androidx.core.widget.NestedScrollView
                android:id="@+id/nestedScrollLearning"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="70dp"
                app:layout_behavior="@string/appbar_scrolling_view_behavior">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvBottomSheet"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:padding="8dp" />

            </androidx.core.widget.NestedScrollView>

        </androidx.coordinatorlayout.widget.CoordinatorLayout>

        <LinearLayout
            android:id="@+id/shimmerParentLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:paddingVertical="20dp"
            android:visibility="gone"
            android:background="@android:color/white">

            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />
            <include layout="@layout/shimmer_layout" />

        </LinearLayout>

    </RelativeLayout>


</androidx.coordinatorlayout.widget.CoordinatorLayout>

