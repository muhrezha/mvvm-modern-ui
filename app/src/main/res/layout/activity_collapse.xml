<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:theme="@style/Theme.MyCRUD.Materials"
    tools:context=".views.AppbarCollapse.CollapseActivity">

    <FrameLayout
        android:id="@+id/frame_dashboard"
        android:background="@color/white"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:cardElevation="20dp"
        android:fitsSystemWindows="false"
        app:cardBackgroundColor="@color/white"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/bottom_nav_dashboard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:fitsSystemWindows="true"
            android:background="@color/white"
            android:elevation="20dp"
            app:elevation="20dp"
            app:menu="@menu/menu_bottom_nav__collapse_fragment"
            app:labelVisibilityMode="labeled"
            app:itemIconTint="@color/bnv_icon_tint"
            app:itemTextColor="@color/bnv_text_tint"
            app:itemRippleColor="@color/bnv_ripple"
            app:itemActiveIndicatorStyle="@style/Widget.BNV.ActiveIndicator"
            />

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>